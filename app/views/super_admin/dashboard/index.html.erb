<% content_for(:title) do %>
  <%= t('super_admin.dashboard.title') %>
<% end %>

<%= render_vue_component('DashboardIndex', {
  accountsCount: @accounts_count,
  usersCount: @users_count,
  inboxesCount: @inboxes_count,
  conversationsCount: @conversations_count,
  chartData: @data,
  labels: {
    title: t('super_admin.dashboard.title'),
    accounts: t('super_admin.dashboard.accounts'),
    users: t('super_admin.dashboard.users'),
    inboxes: t('super_admin.dashboard.inboxes'),
    conversations: t('super_admin.dashboard.conversations')
  }
}) %>
